<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SATI AI • Aureonix</title>
<style>
body {margin:0;font-family:-apple-system,BlinkMacSystemFont,sans-serif;background:#f5f5f7;color:#111;}
.app {max-width:700px;margin:auto;padding:20px;}
header h1 {margin:0;}
#chat {height:400px;overflow-y:auto;background:#fff;padding:20px;border-radius:20px;box-shadow:0 5px 20px rgba(0,0,0,0.05);margin-bottom:15px;}
.message {margin-bottom:10px;padding:12px;border-radius:14px;max-width:80%;}
.user {background:#007aff;color:white;margin-left:auto;}
.bot {background:#e9e9eb;}
.input-area {display:flex;gap:10px;margin-bottom:10px;}
input {flex:1;padding:15px;border-radius:14px;border:1px solid #ddd;font-size:16px;}
button {background:#007aff;color:white;border:none;padding:12px 18px;border-radius:14px;font-weight:600;cursor:pointer;}
.actions {display:flex;gap:10px;margin-bottom:15px;}
</style>
</head>
<body>

<div class="app">
<header>
<h1>SATI AI</h1>
<p>by Aureonix Technologies</p>
</header>

<div id="chat"></div>

<div class="input-area">
<input type="text" id="userInput" placeholder="Digite sua mensagem...">
<button onclick="sendMessage()">Enviar</button>
</div>

<div class="actions">
<button onclick="gerarCodigo()">Gerar Código</button>
<button onclick="gerarAPK()">Baixar APK</button>
<button onclick="alternarIA()">Alternar IA (Gemini/ChatGPT)</button>
</div>
</div>

<script>
// === CONFIGURAÇÃO ===
let usarGemini = true; // true = Gemini, false = ChatGPT
const API_KEY = "COLOQUE_SUA_API_KEY_AQUI"; // substitua pela sua chave Gemini

// === FUNÇÕES DE CHAT ===
function addMessage(text,className){
  const chat = document.getElementById("chat");
  const message = document.createElement("div");
  message.className="message "+className;
  message.innerText=text;
  chat.appendChild(message);
  chat.scrollTop=chat.scrollHeight;
}

async function callGemini(prompt){
  const response = await fetch(
    "https://generativelanguage.googleapis.com/v1beta/models/gemini-pro:generateContent?key="+API_KEY,
    {method:"POST",headers:{"Content-Type":"application/json"},
     body:JSON.stringify({contents:[{parts:[{text:prompt}]}]})
    });
  const data = await response.json();
  return data.candidates[0].content.parts[0].text;
}

async function callChatGPT(prompt){
  // Aqui você pode simular respostas ou usar API futura
  return "Chat GPT diz: Não consigo executar código real ainda, mas posso te explicar.";
}

async function sendMessage(){
  const input = document.getElementById("userInput");
  const text=input.value;
  if(text==="") return;
  addMessage(text,"user");
  input.value="";
  addMessage("SATI AI está pensando...","bot");
  let reply;
  if(usarGemini){
    reply = await callGemini(text);
  } else {
    reply = await callChatGPT(text);
  }
  document.querySelector(".bot:last-child").remove();
  addMessage(reply,"bot");
}

// === GERAR CÓDIGO ===
function gerarCodigo(){
  addMessage("SATI AI: Aqui está um código HTML de exemplo:\n<html><body><h1>Olá Mundo!</h1></body></html>","bot");
}

// === GERAR / BAIXAR APK SIMULADO ===
function gerarAPK(){
  const blob = new Blob(["Conteúdo do APK (simulado)"],{type:"application/octet-stream"});
  const link = document.createElement("a");
  link.href=URL.createObjectURL(blob);
  link.download="SATI_AI.apk";
  link.click();
}

// === ALTERNAR IA ===
function alternarIA(){
  usarGemini = !usarGemini;
  addMessage("Agora usando: "+(usarGemini?"Gemini":"ChatGPT"),"bot");
}
</script>
</body>
</html>
