<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SATI AI Enterprise</title>
<style>
body {margin:0;font-family:-apple-system,BlinkMacSystemFont,sans-serif;background:#f5f5f7;color:#111;}
.app {max-width:900px;margin:auto;padding:15px;}
header h1 {margin:0;}
#tabs {display:flex;gap:5px;margin-bottom:10px;flex-wrap:wrap;}
.tab-btn {flex:1;padding:10px;background:#007aff;color:white;border:none;border-radius:10px;cursor:pointer;font-weight:600;}
.tab-btn.active {background:#005bb5;}
.tab-content {display:none;background:#fff;padding:15px;border-radius:15px;box-shadow:0 5px 20px rgba(0,0,0,0.05);}
.tab-content.active {display:block;}
textarea, input[type=text] {width:100%;padding:12px;border-radius:10px;border:1px solid #ccc;margin-bottom:10px;font-family:monospace;}
button {background:#007aff;color:white;border:none;padding:10px 15px;border-radius:10px;font-weight:600;cursor:pointer;margin-right:5px;}
#chat {height:250px;overflow-y:auto;background:#e9e9eb;padding:10px;border-radius:10px;margin-bottom:10px;}
.message {margin-bottom:8px;padding:8px;border-radius:10px;max-width:80%;}
.user {background:#007aff;color:white;margin-left:auto;}
.bot {background:#ddd;}
#editor {height:250px;overflow-y:auto;}
#builderArea {border:1px solid #ccc;height:250px;padding:10px;margin-top:10px;overflow:auto;}
.project-list {margin-bottom:10px;}
.project-list button {margin:2px;}
</style>
</head>
<body>

<div class="app">
<header>
<h1>SATI AI Enterprise</h1>
<p>Central completa de desenvolvimento móvel</p>
</header>

<div id="tabs">
<button class="tab-btn active" onclick="openTab('chatTab')">Chat AI</button>
<button class="tab-btn" onclick="openTab('editorTab')">Editor / Flutter</button>
<button class="tab-btn" onclick="openTab('appBuilderTab')">App Builder</button>
<button class="tab-btn" onclick="openTab('buildTab')">Build APK</button>
<button class="tab-btn" onclick="openTab('installTab')">Central Instalação</button>
<button class="tab-btn" onclick="openTab('projectsTab')">Projetos</button>
</div>

<!-- CHAT AI -->
<div id="chatTab" class="tab-content active">
<div id="chat"></div>
<input type="text" id="userInput" placeholder="Digite sua mensagem...">
<button onclick="sendMessage()">Enviar</button>
<button onclick="alternarIA()">Alternar IA</button>
</div>

<!-- EDITOR -->
<div id="editorTab" class="tab-content">
<textarea id="editor" placeholder="Escreva seu código Dart, Flutter, JS ou Java aqui..."></textarea>
<button onclick="runEditorCode()">Executar / Simular</button>
</div>

<!-- APP BUILDER -->
<div id="appBuilderTab" class="tab-content">
<p>Arraste e solte componentes para criar seu app:</p>
<button onclick="addButton()">Adicionar Botão</button>
<button onclick="addText()">Adicionar Texto</button>
<div id="builderArea"></div>
</div>

<!-- BUILD APK -->
<div id="buildTab" class="tab-content">
<p>Gerar APK do seu projeto:</p>
<button onclick="gerarAPK()">Gerar / Baixar APK</button>
</div>

<!-- CENTRAL DE INSTALAÇÃO -->
<div id="installTab" class="tab-content">
<h3>Passo a passo para instalar APK</h3>
<ol>
<li>Baixe o APK pelo botão acima.</li>
<li>Vá em Configurações → Segurança → Permitir fontes desconhecidas.</li>
<li>Abra o APK baixado e instale.</li>
<li>Pronto! Seu app está instalado.</li>
</ol>
</div>

<!-- PROJETOS -->
<div id="projectsTab" class="tab-content">
<h3>Projetos Salvos</h3>
<div class="project-list" id="projectList"></div>
<input type="text" id="newProjectName" placeholder="Nome do projeto">
<button onclick="saveProject()">Salvar Projeto</button>
</div>

</div>

<script>
// === CONFIGURAÇÃO ===
let usarGemini = true;
const API_KEY = "COLOQUE_SUA_API_KEY_AQUI"; // substitua pela sua chave Gemini
let projetos = {};

// === ABAS ===
function openTab(tabId){
  document.querySelectorAll('.tab-btn').forEach(btn=>btn.classList.remove('active'));
  document.querySelectorAll('.tab-content').forEach(tc=>tc.classList.remove('active'));
  document.querySelector(`[onclick*="${tabId}"]`).classList.add('active');
  document.getElementById(tabId).classList.add('active');
}

// === CHAT AI ===
function addMessage(text,className){
  const chat = document.getElementById("chat");
  const message = document.createElement("div");
  message.className="message "+className;
  message.innerText=text;
  chat.appendChild(message);
  chat.scrollTop=chat.scrollHeight;
}

async function callGemini(prompt){
  const response = await fetch(
    "https://generativelanguage.googleapis.com/v1beta/models/gemini-pro:generateContent?key="+API_KEY,
    {method:"POST",headers:{"Content-Type":"application/json"},
     body:JSON.stringify({contents:[{parts:[{text:prompt}]}]})
    });
  const data = await response.json();
  return data.candidates[0].content.parts[0].text;
}

async function callChatGPT(prompt){
  return "Chat GPT diz: Não consigo executar código real ainda, mas posso te explicar.";
}

async function sendMessage(){
  const input = document.getElementById("userInput");
  const text=input.value;
  if(text==="") return;
  addMessage(text,"user");
  input.value="";
  addMessage("SATI AI está pensando...","bot");
  let reply;
  if(usarGemini){
    reply = await callGemini(text);
  } else {
    reply = await callChatGPT(text);
  }
  document.querySelector(".bot:last-child")?.remove();
  addMessage(reply,"bot");
}

function alternarIA(){
  usarGemini = !usarGemini;
  addMessage("Agora usando: "+(usarGemini?"Gemini":"ChatGPT"),"bot");
}

// === EDITOR ===
function runEditorCode(){
  const code = document.getElementById("editor").value;
  alert("Simulação de execução:\n"+code);
}

// === APP BUILDER ===
function addButton(){
  const area = document.getElementById("builderArea");
  const btn = document.createElement("button");
  btn.innerText="Botão";
  btn.style.margin="5px";
  area.appendChild(btn);
}
function addText(){
  const area = document.getElementById("builderArea");
  const p = document.createElement("p");
  p.innerText="Texto";
  p.style.margin="5px";
  area.appendChild(p);
}

// === BUILD APK SIMULADO ===
function gerarAPK(){
  const blob = new Blob(["Conteúdo do APK do seu projeto"],{type:"application/octet-stream"});
  const link = document.createElement("a");
  link.href=URL.createObjectURL(blob);
  link.download="SATI_AI_Enterprise.apk";
  link.click();
}

// === PROJETOS ===
function saveProject(){
  const name = document.getElementById("newProjectName").value.trim();
  if(!name) return alert("Digite um nome para o projeto");
  projetos[name] = document.getElementById("editor").value + "\n" + document.getElementById("builderArea").innerHTML;
  updateProjectList();
}

function updateProjectList(){
  const listDiv = document.getElementById("projectList");
  listDiv.innerHTML="";
  for(const p in projetos){
    const btn = document.createElement("button");
    btn.innerText=p;
    btn.onclick=()=>loadProject(p);
    listDiv.appendChild(btn);
  }
}

function loadProject(name){
  const content = projetos[name].split("\n");
  document.getElementById("editor").value = content[0];
  document.getElementById("builderArea").innerHTML = content[1] || "";
  alert("Projeto '"+name+"' carregado!");
}
</script>
</body>
</html>
